<Window x:Class="silly.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:silly"
        xmlns:gif="http://wpfanimatedgif.codeplex.com"
        mc:Ignorable="d"
        MouseMove="MoveImage"
        Loaded="FadeIn"
        Closing="FadeOut"
        KeyUp="keyPress"
        Title="silly" Height="480" Width="640" Icon="/icon.jpg" ResizeMode="NoResize" WindowStartupLocation="CenterScreen" WindowStyle="None" AllowsTransparency="True" Background="#00000000">
    <Grid>
        <Canvas Background="Black">
            <Image x:Name="anime" Source="/115507119_p0.jpg" Stretch="UniformToFill" Width="680" Height="520" HorizontalAlignment="Left" VerticalAlignment="Top" Canvas.Left="-20" Canvas.Top="-20" Opacity="0.5" MouseLeftButtonDown="dragging">
                <Image.Effect>
                    <BlurEffect Radius="8" RenderingBias="Quality"></BlurEffect>
                </Image.Effect>
            </Image>
        </Canvas>
        <Label x:Name="lblMessage" Content="message" HorizontalAlignment="Center" VerticalAlignment="Top" Foreground="White" FontSize="16" RenderTransformOrigin="0.511,0.072" Margin="0,10,0,0">
            <Label.Effect>
                <DropShadowEffect RenderingBias="Quality" BlurRadius="0" ShadowDepth="2"/>
            </Label.Effect>
        </Label>
        <Button x:Name="btnClick" HorizontalAlignment="Center" VerticalAlignment="Center" Content="click me :3" FontSize="16" Click="btnClick_Click" Background="White" BorderBrush="Gray" Width="101" Height="35"></Button>
        <CheckBox x:Name="checkMousePos" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Content="get mouse pos" Foreground="White" BorderBrush="Gray" Margin="0,100,150,0" Checked="startPosRelay"></CheckBox>
        <Image x:Name="KonosubaGif" gif:ImageBehavior.AnimatedSource="/output.gif" Opacity="0" Stretch="UniformToFill" HorizontalAlignment="Left" Width="480" Margin="65,290,0,0" VerticalAlignment="Top"/>
        <CheckBox x:Name="checkKonosuba" VerticalAlignment="Center" FontSize="16" Content="konosuba" Foreground="White" BorderBrush="Gray" Margin="150,100,0,0" Checked="showKonosubaGif" HorizontalAlignment="Center"/>
    </Grid>
</Window>
